{
  "name": "predaiot",
  "version": "1.0.0",
  "private": true,
  "description": "PREDAIOT — Economic Decision Intelligence for Energy Assets (Oman / GCC)",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"next dev -p 3000\" \"npm:dev:api\"",
    "dev:api": "tsx watch server.ts",
    "dev:web": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "start:api": "tsx server.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "airtable": "^0.12.2",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^1.4.5-lts.1",
    "next": "^16.2.9",
    "next-intl": "^4.13.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resend": "^6.14.0",
    "twilio": "^6.0.2",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.1.14",
    "@tailwindcss/postcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
