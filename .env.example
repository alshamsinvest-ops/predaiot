# =========================================================================
# PREDAIOT — environment template. Copy to .env.local and fill in.
# NEVER commit real secrets. .env.local is gitignored.
# =========================================================================

# ---- Frontend (Next.js) — must be NEXT_PUBLIC_ to reach the browser ----
NEXT_PUBLIC_API_URL="http://localhost:8787"           # Express API base (prod: https://preda-iot.com)
NEXT_PUBLIC_GOOGLE_CALENDAR_URL=""                    # Google Calendar appointment embed URL (booking)

# Firebase web config (client). Either provide the JSON blob...
NEXT_PUBLIC_FIREBASE_CONFIG=''                        # {"apiKey":"...","authDomain":"...",...}
# ...or the individual fields:
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

GOOGLE_CLIENT_ID=""                                   # Google OAuth2 client ID (Firebase Auth provider)

# ---- Firebase Admin (server / Next.js session route) ----
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY=""                         # keep literal \n escapes

# ---- Backend (Express server.ts) ----
API_PORT="8787"
CORS_ORIGINS="http://localhost:3000"                  # comma-separated allowed origins

# Anthropic Claude (PREDAIOT Copilot — claude-sonnet-4-6)
ANTHROPIC_API_KEY=""

# Airtable CRM (base + table fixed per spec)
AIRTABLE_API_KEY=""
AIRTABLE_BASE_ID="appeUbnHpGamghy8q"
AIRTABLE_TABLE_ID="tbl6r1kqhvRN4IDgI"

# Twilio WhatsApp Business
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"        # your Twilio WhatsApp sender
WHATSAPP_TO="+96874114028"                            # where lead notifications are delivered (E.164)

# Resend email
RESEND_API_KEY=""
RESEND_FROM="PREDAIOT <noreply@preda-iot.com>"
